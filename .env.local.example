# ClaimShield DV - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control

# ============================================
# DATABASE
# ============================================
# Neon PostgreSQL connection string
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
DATABASE_URL="postgresql://user:password@host.neon.tech/claimshield_dv?sslmode=require"

# ============================================
# AUTHENTICATION (Clerk)
# ============================================
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk URLs (usually don't need to change these)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# ============================================
# AI (Google Gemini)
# ============================================
# Get from https://makersuite.google.com/app/apikey
GEMINI_API_KEY="AIza..."

# ============================================
# FILE STORAGE (Vercel Blob)
# ============================================
# Get from Vercel Dashboard → Storage
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ============================================
# WEB SCRAPING (Apify)
# ============================================
# Get from https://console.apify.com/account/integrations
APIFY_API_TOKEN="apify_api_..."

# ============================================
# PAYMENTS (Stripe)
# ============================================
# Get from https://dashboard.stripe.com/apikeys
# Use test keys for development, live keys for production
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook signing secret from Stripe Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET="whsec_..."

# ============================================
# EMAIL (SendGrid)
# ============================================
# Get from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY="SG...."

# Verified sender email
SENDGRID_FROM_EMAIL="reports@claimshield-dv.com"

# ============================================
# APPLICATION
# ============================================
# Your application URL (use localhost for development)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Node environment
NODE_ENV="development"

# ============================================
# OPTIONAL: MONITORING & LOGGING
# ============================================
# Sentry DSN (for error tracking)
# NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."

# ============================================
# NOTES
# ============================================
# 1. Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# 2. All other variables are server-side only
# 3. Never commit this file with real values
# 4. Use different values for development, staging, and production
# 5. Rotate API keys regularly for security
